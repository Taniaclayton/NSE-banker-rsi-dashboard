# Copy this file to .env and edit with your actual values.

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nse_eod
DB_USER=your_db_username
DB_PASSWORD=your_db_password


PYTHON_PATH=python3.12 #change to your python path if needed

# Folder containing your NSE bhavcopy CSV files (*_NSE.csv or NSE_*.csv)
EOD_FOLDER=./data
LOADER_SCRIPT=./nse_to_mysql_with_banker_signal.py
# Comma-separated series to load (leave blank to load all)
SERIES_FILTER=EQ

# Flask API port
FLASK_PORT=5001
