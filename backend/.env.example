# Copy this file to .env and edit with your actual values.

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nse_eod
DB_USER=root
DB_PASSWORD=root

# Folder containing your NSE bhavcopy CSV files (*_NSE.csv or NSE_*.csv)
EOD_FOLDER=/path/to/bhavcopy

# Comma-separated series to load (leave blank to load all)
SERIES_FILTER=EQ

# Flask API port
FLASK_PORT=5001
